    SNOWRole -.->|SNOWAddSearchOptimization| SNOWSchema
    SNOWRole -.->|SNOWAddSearchOptimization| SNOWSchema

    SNOWRole -.->|SNOWOwnership| SNOWFunction
    SNOWRole -.->|SNOWUsage| SNOWFunction

    SNOWRole -.->|SNOWOwnership| SNOWProcedure
    SNOWRole -.->|SNOWUsage| SNOWProcedure

    SNOWRole -.->|SNOWOwnership| SNOWStage
    SNOWRole -.->|SNOWRead| SNOWStage
