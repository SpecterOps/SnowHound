    SNOW_ApplicationRole -.->|SNOW_Select| SNOW_View
    SNOW_ApplicationRole -.->|SNOW_Truncate| SNOW_Table
    SNOW_ApplicationRole -.->|SNOW_Usage| SNOW_Database
    SNOW_ApplicationRole -.->|SNOW_Usage| SNOW_Procedure
    SNOW_ApplicationRole -.->|SNOW_Usage| SNOW_Schema
    
    SNOW_Database -.->|SNOW_Contains| SNOW_Schema
    
    SNOW_Schema -.->|SNOW_Contains| SNOW_Function
    SNOW_Schema -.->|SNOW_Contains| SNOW_Procedure
    SNOW_Schema -.->|SNOW_Contains| SNOW_Stage
    SNOW_Schema -.->|SNOW_Contains| SNOW_Table
    SNOW_Schema -.->|SNOW_Contains| SNOW_View

    SNOW_User -.->|SNOW_Usage| SNOW_Role

    SNOW_Role -.->|SNOW_CreateSchema| SNOW_Database
    SNOW_Role -.->|SNOW_Modify| SNOW_Database
    SNOW_Role -.->|SNOW_Ownership| SNOW_Database
