---
config:
  layout: elk
---
flowchart TD
    SNOW_Account[fa:fa-building SNOW_Account]
    SNOW_Application[fa:fa-window-maximize SNOW_Application]
    SNOW_ApplicationRole[fa:fa-user-shield SNOW_ApplicationRole]
    SNOW_Database[fa:fa-database SNOW_Database]
    SNOW_Function[fa:fa-code SNOW_Function]
    SNOW_Integration[fa:fa-user-tie SNOW_Integration]
    SNOW_Procedure[fa:fa-cogs SNOW_Procedure]
    SNOW_Role[fa:fa-user-group SNOW_Role]
    SNOW_Schema[fa:fa-network-wired SNOW_Schema]
    SNOW_Stage[fa:fa-layer-group SNOW_Stage]
    SNOW_Table[fa:fa-table SNOW_Table]
    SNOW_User[fa:fa-user SNOW_User]
    SNOW_View[fa:fa-eye SNOW_View]
    SNOW_Warehouse[fa:fa-warehouse SNOW_Warehouse]

    style SNOW_Account fill:#5FED83
    style SNOW_Application fill:#A1C6EA
    style SNOW_ApplicationRole fill:#C6C3FF
    style SNOW_Database fill:#FF80D2
    style SNOW_Function fill:#A9E5E5
    style SNOW_Integration fill:#BFFFD1
    style SNOW_Procedure fill:#D8C8F8
    style SNOW_Role fill:#C06EFF
    style SNOW_Schema fill:#DEFEFA
    style SNOW_Stage fill:#80E0C6
    style SNOW_Table fill:#FFD2A6
    style SNOW_User fill:#FF8E40
    style SNOW_View fill:#A6E0FF
    style SNOW_Warehouse fill:#9EECFF
    
    SNOW_Account -.->|SNOW_Contains| SNOW_Application
    SNOW_Account -.->|SNOW_Contains| SNOW_ApplicationRole
    SNOW_Account -.->|SNOW_Contains| SNOW_Database
    SNOW_Account -.->|SNOW_Contains| SNOW_Function
    SNOW_Account -.->|SNOW_Contains| SNOW_Integration
    SNOW_Account -.->|SNOW_Contains| SNOW_Procedure
    SNOW_Account -.->|SNOW_Contains| SNOW_Role
    SNOW_Account -.->|SNOW_Contains| SNOW_Schema
    SNOW_Account -.->|SNOW_Contains| SNOW_Stage
    SNOW_Account -.->|SNOW_Contains| SNOW_Table
    SNOW_Account -.->|SNOW_Contains| SNOW_User
    SNOW_Account -.->|SNOW_Contains| SNOW_View
    SNOW_Account -.->|SNOW_Contains| SNOW_Warehouse
    
    SNOW_Application -.->|SNOW_Contains| SNOW_ApplicationRole
    SNOW_Application -.->|SNOW_ExecuteManagedTask| SNOW_Account
    SNOW_Application -.->|SNOW_ExecuteTask| SNOW_Account

    SNOW_ApplicationRole -.->|SNOW_Delete| SNOW_Table
