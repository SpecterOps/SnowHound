---
config:
  layout: elk
---
flowchart TD
    SNOWAccount[fa:fa-building SNOWAccount]
    SNOWApplication[fa:fa-window-maximize SNOWApplication]
    SNOWApplicationRole[fa:fa-user-shield SNOWApplicationRole]
    SNOWDatabase[fa:fa-database SNOWDatabase]
    SNOWFunction[fa:fa-code SNOWFunction]
    SNOWIntegration[fa:fa-user-tie SNOWIntegration]
    SNOWProcedure[fa:fa-cogs SNOWProcedure]
    SNOWRole[fa:fa-user-group SNOWRole]
    SNOWSchema[fa:fa-network-wired SNOWSchema]
    SNOWStage[fa:fa-layer-group SNOWStage]
    SNOWTable[fa:fa-table SNOWTable]
    SNOWUser[fa:fa-user SNOWUser]
    SNOWView[fa:fa-eye SNOWView]
    SNOWWarehouse[fa:fa-warehouse SNOWWarehouse]

    style SNOWAccount fill:#5FED83
    style SNOWApplication fill:#A1C6EA
    style SNOWApplicationRole fill:#C6C3FF
    style SNOWDatabase fill:#FF80D2
    style SNOWFunction fill:#A9E5E5
    style SNOWIntegration fill:#BFFFD1
    style SNOWProcedure fill:#D8C8F8
    style SNOWRole fill:#C06EFF
    style SNOWSchema fill:#DEFEFA
    style SNOWStage fill:#80E0C6
    style SNOWTable fill:#FFD2A6
    style SNOWUser fill:#FF8E40
    style SNOWView fill:#A6E0FF
    style SNOWWarehouse fill:#9EECFF
    
    SNOWAccount -.->|SNOWContains| SNOWApplication
    SNOWAccount -.->|SNOWContains| SNOWApplicationRole
    SNOWAccount -.->|SNOWContains| SNOWDatabase
    SNOWAccount -.->|SNOWContains| SNOWFunction
    SNOWAccount -.->|SNOWContains| SNOWIntegration
    SNOWAccount -.->|SNOWContains| SNOWProcedure
    SNOWAccount -.->|SNOWContains| SNOWRole
    SNOWAccount -.->|SNOWContains| SNOWSchema
    SNOWAccount -.->|SNOWContains| SNOWStage
    SNOWAccount -.->|SNOWContains| SNOWTable
    SNOWAccount -.->|SNOWContains| SNOWUser
    SNOWAccount -.->|SNOWContains| SNOWView
    SNOWAccount -.->|SNOWContains| SNOWWarehouse
    
    SNOWApplication -.->|SNOWContains| SNOWApplicationRole
    SNOWApplication -.->|SNOWExecuteManagedTask| SNOWAccount
    SNOWApplication -.->|SNOWExecuteTask| SNOWAccount

    SNOWApplicationRole -.->|SNOWDelete| SNOWTable
    SNOWApplicationRole -.->|SNOWSelect| SNOWTable
    SNOWApplicationRole -.->|SNOWSelect| SNOWView
    SNOWApplicationRole -.->|SNOWTruncate| SNOWTable
    SNOWApplicationRole -.->|SNOWUsage| SNOWDatabase
    SNOWApplicationRole -.->|SNOWUsage| SNOWProcedure
    SNOWApplicationRole -.->|SNOWUsage| SNOWSchema
    
    SNOWDatabase -.->|SNOWContains| SNOWSchema
    
    SNOWSchema -.->|SNOWContains| SNOWFunction
    SNOWSchema -.->|SNOWContains| SNOWProcedure
    SNOWSchema -.->|SNOWContains| SNOWStage
    SNOWSchema -.->|SNOWContains| SNOWTable
    SNOWSchema -.->|SNOWContains| SNOWView

    SNOWStage -.->|SNOWUsesStorageIntegration| SNOWIntegration

    SNOWUser -.->|SNOWUsage| SNOWRole

    SNOWRole -.->|SNOWCreateSchema| SNOWDatabase
    SNOWRole -.->|SNOWModify| SNOWDatabase
    SNOWRole -.->|SNOWOwnership| SNOWDatabase
    SNOWRole -.->|SNOWUsage| SNOWDatabase

    SNOWRole -.->|SNOWModify| SNOWSchema
    SNOWRole -.->|SNOWMonitor| SNOWSchema
