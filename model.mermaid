    SNOWRole -.->|SNOWCreateServiceClass| SNOWSchema
    SNOWRole -.->|SNOWCreateSessionPolicy| SNOWSchema
    SNOWRole -.->|SNOWCreateSnapshot| SNOWSchema
    SNOWRole -.->|SNOWCreateStage| SNOWSchema
