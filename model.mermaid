    SNOWRole -.->|SNOWOwnership| SNOWIntegration
    SNOWRole -.->|SNOWUsage| SNOWIntegration
    SNOWRole -.->|SNOWUseAnyRole| SNOWIntegration

    SNOWRole -.->|SNOWOwnership| SNOWRole
